{
    "name": "bitdigitalcodes/statamic-chatgpt",
    "type": "statamic-addon",
    "version": "2.0.0",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bitdigital\\StatamicChatgpt\\": "src"
        }
    },
    "extra": {
        "statamic": {
            "name": "ChatGPT",
            "description": "ChatGPT addon that allows you to add AI-generated content to your website. Supports adding content to the editor, supporting multiple models."
        },
        "laravel": {
            "providers": [
                "Bitdigital\\StatamicChatgpt\\ServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "statamic/cms": "^6.0",
        "openai-php/laravel": "^0.20",
        "ueberdosis/tiptap-php": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true,
            "php-http/discovery": true
        }
    }
}
